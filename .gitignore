# ══════════════════════════════════════════════
#  SyncBeat — .gitignore
#  Place this file at: syncbeat/.gitignore
# ══════════════════════════════════════════════

# ── Node modules (never commit these) ─────────
node_modules/
backend/node_modules/
frontend/node_modules/

# ── Environment files (contain secrets) ───────
.env
.env.local
.env.development
.env.production
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# ── Uploaded audio files ──────────────────────
backend/uploads/*
!backend/uploads/.gitkeep

# ── React production build ────────────────────
frontend/build/

# ── Package lock files (optional but cleaner) ─
package-lock.json
backend/package-lock.json
frontend/package-lock.json

# ── Logs ──────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS generated files ────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini

# ── Editor files ──────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo